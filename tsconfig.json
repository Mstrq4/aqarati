{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@aqarati/shared/*": ["./shared/*"],
      "@aqarati/mobile/*": ["./mobile/src/*"],
      "@aqarati/admin/*": ["./admin/src/*"],
      "@aqarati/web/*": ["./web/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "build", "target"]
}
