# Aqarati — Environment Configuration
# Copy this file to .env and fill in your values

# ─── Database ──────────────────────────────────────
# Database engine: "postgresql" or "mysql"
DB_ENGINE=postgresql
# PostgreSQL connection (used when DB_ENGINE=postgresql)
DATABASE_URL=postgres://user:password@hostinger-host:5432/aqarati
# MySQL connection (used when DB_ENGINE=mysql)
# DATABASE_URL=mysql://user:password@hostinger-host:3306/aqarati

# ─── Authentication ────────────────────────────────
JWT_SECRET=generate-a-random-64-character-secret-here
JWT_EXPIRY_HOURS=720

# ─── Server ────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=https://aqarati.vercel.app,https://admin.aqarati.vercel.app,http://localhost:*

# ─── Storage ────────────────────────────────────────
STORAGE_PATH=./storage/uploads
STORAGE_URL=/uploads

# ─── Email ─────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@aqarati.app
SMTP_PASSWORD=your-smtp-password

# ─── Payments (Saudi Arabia) ───────────────────────
# HyperPay / Moyasar / Tap / Checkout.com — enable via admin panel
PAYMENT_PROVIDERS=mada,apple_pay,stc_pay,visa,mastercard

# ─── AI (Phase 2 only) ────────────────────────────
OPENAI_API_KEY=sk-...
AI_ENABLED=false

# ─── Feature Flags ─────────────────────────────────
DEMO_MODE=false
PLAYGROUND_ENABLED=false
